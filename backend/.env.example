DATABASE_URL="file:./app.db"

# OpenRouter API Key (用于 DeepSeek V3.2 真伪识别和相关性分析)
# 注册地址: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_key_here

# Twitter API (twitterapi.io) - 可选
# 注册地址: https://twitterapi.io/
TWITTERAPI_IO_KEY=your_twitterapi_io_key_here

# 设置为 true 开启 Twitter 爬取（默认关闭）
ENABLE_TWITTER=false

NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:5173

# SMTP 邮件推送配置（用于超高热点提醒和测试邮件）
# 注意：仅填写收件邮箱不够，必须配置发件 SMTP 账号。
# QQ 邮箱示例: smtp.qq.com:465（SMTP_PASS 使用授权码，不是登录密码）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_sender@qq.com
SMTP_PASS=your_smtp_auth_code
SMTP_FROM=your_sender@qq.com
